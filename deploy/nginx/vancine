# Vancine Platform - Nginx Configuration
#
# Server: 27.124.22.102
# Path:   /etc/nginx/sites-enabled/vancine
#
# After editing, run: nginx -t && systemctl reload nginx
#
# Changelog:
#   2026-06-25  Migrated production from 64.83.35.21 to 27.124.22.102.
#   2026-06-12  Replaced X-Frame-Options: SAMEORIGIN with CSP frame-ancestors
#               to allow Cloudflare Turnstile cross-origin iframe rendering.

# api.vancine.com -> vancine.com redirect
server {
    server_name api.vancine.com;

    listen 443 ssl;
    ssl_certificate /etc/letsencrypt/live/vancine.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/vancine.com/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    return 301 https://vancine.com$request_uri;
}

# Main site - vancine.com
server {
    server_name vancine.com www.vancine.com;

    location /.well-known/acme-challenge/ {
        root /var/www/html;
    }

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_connect_timeout 60s;
        proxy_send_timeout 120s;
        proxy_read_timeout 120s;

        # Security headers
        # frame-ancestors replaces X-Frame-Options to allow Turnstile iframe
        add_header Content-Security-Policy "frame-ancestors 'self' https://challenges.cloudflare.com;" always;
        add_header X-Content-Type-Options "nosniff" always;
        add_header X-XSS-Protection "1; mode=block" always;
        add_header Referrer-Policy "strict-origin-when-cross-origin" always;
        add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

        client_max_body_size 20m;
        proxy_buffering on;
        proxy_buffer_size 128k;
        proxy_buffers 4 256k;
    }

    listen 443 ssl;
    ssl_certificate /etc/letsencrypt/live/vancine.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/vancine.com/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;
}

# HTTP redirect to HTTPS
server {
    listen 80;
    server_name vancine.com www.vancine.com api.vancine.com;
    return 301 https://$host$request_uri;
}
